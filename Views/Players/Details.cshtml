@model web.Models.Player

@{
    ViewData["Title"] = "Player Details";
}

<div class="players-details">
    <h1 style="color: #FFD700; text-align: center; text-shadow: 0 0 10px #FF4500;">Player Details</h1>

    <div class="details-content">
        <dl class="row">
            <dt class="col-sm-4">Username</dt>
            <dd class="col-sm-8">@Model.Username</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Balance</dt>
            <dd class="col-sm-8">@Model.Balance</dd>
        </dl>
    </div>

    <div class="details-buttons">
        <a asp-action="Edit" asp-route-id="@Model.ID_player" class="btn btn-primary custom-edit-btn">Edit</a>
        <a asp-action="Index" class="btn btn-secondary custom-back-btn">Back to List</a>
    </div>
</div>

<style>

.players-details {
    background-color: #2C2C2C; 
    color: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);
    margin: 20px auto;
    max-width: 600px; 
    text-align: left;
}


.details-content dt {
    color: #FFD700; 
    font-weight: bold;
}

.details-content dd {
    color: white; 
    margin-bottom: 10px;
}


.custom-edit-btn {
    background-color: #FF4500;
    color: white;
    border: none;
    padding: 10px 20px;
    text-transform: uppercase;
    border-radius: 5px;
    transition: all 0.3s ease;
    text-decoration: none;
    margin-right: 10px;
}

.custom-edit-btn:hover {
    background-color: #FF6347; 
    color: black;
}

.custom-back-btn {
    background-color: #3C3C3C;
    color: white;
    border: 1px solid #FFD700;
    padding: 10px 20px;
    text-transform: uppercase;
    border-radius: 5px;
    transition: all 0.3s ease;
    text-decoration: none;
}

.custom-back-btn:hover {
    background-color: #444;
    color: #FFD700;
    border-color: #FF4500;
}
</style>
