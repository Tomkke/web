@model web.Models.GameState

@{
    ViewData["Title"] = "Game State Details";
}

<div class="gamestates-details">
    <h1 style="color: #FFD700; text-align: center; text-shadow: 0 0 10px #FF4500;">Game State Details</h1>

    <div class="details-content">
        <dl class="row">
            <dt class="col-sm-4">Total Wins</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.TotalWins)</dd>

            <dt class="col-sm-4">Total Losses</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.TotalLosses)</dd>

            <dt class="col-sm-4">Total Profit/Loss</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.TotalProfitLoss)</dd>

            <dt class="col-sm-4">Player</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Player.Email)</dd>

            <dt class="col-sm-4">Game</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Game.Game_description)</dd>
        </dl>
    </div>

    <div class="details-buttons">
        <a asp-action="Edit" asp-route-id="@Model?.ID_stats" class="btn btn-primary custom-edit-btn">Edit</a>
        <a asp-action="Index" class="btn btn-secondary custom-back-btn">Back to List</a>
    </div>
</div>

<style>

.gamestates-details {
    background-color: #2C2C2C; 
    color: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);
    margin: 20px auto;
    max-width: 600px; 
    text-align: left;
}


.details-content dt {
    color: #FFD700; 
    font-weight: bold;
}

.details-content dd {
    color: white; 
    margin-bottom: 10px;
}


.custom-edit-btn {
    background-color: #FF4500; 
    color: white;
    border: none;
    padding: 10px 20px;
    text-transform: uppercase;
    border-radius: 5px;
    transition: all 0.3s ease;
    text-decoration: none;
    margin-right: 10px;
}

.custom-edit-btn:hover {
    background-color: #FF6347; 
    color: black;
}

.custom-back-btn {
    background-color: #3C3C3C; 
    color: white;
    border: 1px solid #FFD700;
    padding: 10px 20px;
    text-transform: uppercase;
    border-radius: 5px;
    transition: all 0.3s ease;
    text-decoration: none;
}

.custom-back-btn:hover {
    background-color: #444; 
    color: #FFD700; 
    border-color: #FF4500; 
}
</style>
