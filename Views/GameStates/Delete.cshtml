@model web.Models.GameState

@{
    ViewData["Title"] = "Delete Game State";
}

<div class="gamestates-delete">
    <h1 style="color: #FF4500; text-align: center; text-shadow: 0 0 10px #FFD700;">Confirm Deletion</h1>

    <p style="text-align: center; margin: 20px 0;">
        Are you sure you want to delete this game state?
    </p>

    <div class="details-content">
        <dl class="row">
            <dt class="col-sm-4">Total Wins</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.TotalWins)</dd>

            <dt class="col-sm-4">Total Losses</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.TotalLosses)</dd>

            <dt class="col-sm-4">Total Profit/Loss</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.TotalProfitLoss)</dd>

            <dt class="col-sm-4">Player</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Player.Email)</dd>

            <dt class="col-sm-4">Game</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Game.Game_description)</dd>
        </dl>
    </div>

    <form asp-action="Delete" method="post" style="text-align: center; margin-top: 20px;">
        <input type="hidden" asp-for="ID_stats" />
        <button type="submit" class="btn btn-danger custom-delete-btn">Delete</button>
        <a asp-action="Index" class="btn btn-secondary custom-cancel-btn">Cancel</a>
    </form>
</div>

<style>

.gamestates-delete {
    background-color: #2C2C2C;
    color: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);
    margin: 20px auto;
    max-width: 600px; 
    text-align: left;
}


.details-content dt {
    color: #FFD700; 
    font-weight: bold;
}

.details-content dd {
    color: white; 
    margin-bottom: 10px;
}


.custom-delete-btn {
    background-color: #FF0000; 
    color: white;
    border: none;
    padding: 10px 20px;
    text-transform: uppercase;
    border-radius: 5px;
    transition: all 0.3s ease;
    text-decoration: none;
    margin-right: 10px;
}

.custom-delete-btn:hover {
    background-color: #FF6347; 
    color: black;
}

.custom-cancel-btn {
    background-color: #3C3C3C; 
    color: white;
    border: 1px solid #FFD700;
    padding: 10px 20px;
    text-transform: uppercase;
    border-radius: 5px;
    transition: all 0.3s ease;
    text-decoration: none;
}

.custom-cancel-btn:hover {
    background-color: #444; 
    color: #FFD700; 
    border-color: #FF4500; 
}
</style>
