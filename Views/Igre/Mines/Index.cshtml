@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mines";
}

<header>
    <div class="userDiv">
        <i id="user" class="fas fa-user"></i>
        <p id="username"></p>
        <p>🥩</p>
        <p id="usermeat"></p>
    </div>
</header>


<div class="container">

    <i id="info" class="fa-solid fa-circle-info"></i>


    <div class="modal" id="infoModal">
        <div class="modal-content">
            <span class="close" id="closeModal">&times;</span>
            <h2>Mines</h2>
            <ul>
                <li>Začni igro tako, da nastaviš <strong>Bet Size</strong> in <strong>Number of Mines</strong>.</li>
                <li>Odkrivaj polja na mreži: <strong>💎</strong> pomeni varno polje, <strong>💣</strong> pomeni mino in takojšen konec runde.</li>
                <li>Vsak uspešno odkrit <strong>💎</strong> poveča <strong>multiplier</strong> in s tem tudi tvoj potencialni izplačilni znesek.</li>
                <li>Kadarkoli lahko pritisneš <strong>Cashout</strong> in zaključiš rundo z izplačilom trenutnega profita.</li>
            </ul>

        </div>
    </div>




    <div class="controls">
        <label for="betSize">Bet Size:</label>
        <div class="bet-container">
            <input type="number" id="betSize" placeholder="0" min="0.01">
            <span class="currency-symbol">🥩</span>
        </div>

        <label for="mines">Number of Mines:</label>
        <input type="number" id="mines" value="3" min="1" max="24">
        
        <label for="profitInput">Current Profit:</label>
        <div class="bet-container">
            <input type="text" id="profitInput" value="0.00" readonly>
            <span class="currency-symbol">🥩</span>
        </div>
        
        <button id="start">Start Game</button>
        
        <button id="cashout" class="cashout-button" disabled>Cashout</button>

        <button id="exit">Exit</button>
    </div>
    <div id="grid" class="grid"></div>

    <div id="resultModal">
        <div class="modal-content">
            <h2 id="resultTitle"></h2>
            <p id="resultMessage"></p>
            <div class="result-actions">
                <button id="playAgainButton">Play Again</button>
                <button id="endGameButton">End Game</button>
            </div>
        </div>
    </div>

    
</div>

<p id="message"></p>


<div id="toast" class="toast hidden">
    <span id="toastMessage"></span>
</div>

@section Scripts {
<script>


function showToast(message, type = "success") {
    const toast = document.getElementById("toast");
    const toastMessage = document.getElementById("toastMessage");

    toastMessage.textContent = message;
    toast.className = `toast show ${type}`;

    setTimeout(() => {
        toast.classList.remove("show");
        toast.classList.add("hidden");
    }, 3000);
}


const infoIcon = document.getElementById('info');
const infoModal = document.getElementById('infoModal');
const closeModal = document.getElementById('closeModal');

infoIcon.addEventListener('click', () => {
    infoModal.style.display = 'block';
});
closeModal.addEventListener('click', () => {
    infoModal.style.display = 'none';
});
window.addEventListener('click', (event) => {
    if (event.target === infoModal) {
        infoModal.style.display = 'none';
    }
});



let balance = parseFloat("@ViewBag.Balance".replace(',', '.')) || 0;
let startingBalance = balance;
let currentBet = 0;


document.querySelector('#username').textContent = "@ViewBag.Username";
document.getElementById('usermeat').textContent = balance.toFixed(2);

let totalWin = 0;
let totalLoss = 0;
let gameOver = false; 

const gridElement = document.getElementById("grid");
const minesInput = document.getElementById("mines");
const betSizeInput = document.getElementById("betSize");
const startButton = document.getElementById("start");
const cashoutButton = document.getElementById("cashout");
const profitInput = document.getElementById("profitInput");
const exitButton = document.getElementById("exit");

const resultModal = document.getElementById("resultModal");
const resultTitle = document.getElementById("resultTitle");
const resultMessage = document.getElementById("resultMessage");
const playAgainButton = document.getElementById("playAgainButton");
const endGameButton = document.getElementById("endGameButton");


exitButton.addEventListener("click", () => {
    const idPlayer = parseInt("@ViewBag.PlayerId");
    
    
    const sessionProfit = balance - startingBalance;

    fetch("/Igre/PosodobiBalance", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({ idPlayer, sessionProfit }) 
    })
    .then(response => {
        if (response.ok) {
            return response.json();
        } else {
            throw new Error("Failed to update balance.");
        }
    })
    .then(data => {
        
    })
    .catch(error => {
        console.error("Error:", error);
        alert("An error occurred.");
    });
    

   



    
    const idGame = 6; 

    const data = {
        TotalWins: totalWin,
        TotalLosses: totalLoss,
        ID_player: idPlayer,
        ID_game: idGame
    };

    fetch("/Igre/InsertGameState", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        if (response.ok) {
            
        } else {
            alert("Failed to insert GameState.");
        }
    })
    .catch(error => {
        console.error("Error:", error);
        alert("An error occurred.");
    });

    
    window.location.href = "@Url.Action("Index", "Casino")";
});



const SIZE = 5; 
let minePositions = [];
let revealedCells = 0;
let betSize = 0;
let currentProfit = 0;

const sounds = {
    start: "/igre/Mines/media/start.mp3",
    cashout: "/igre/Mines/media/cashout.mp3",
    emerald: "/igre/Mines/media/emerald.mp3",
    mine: "/igre/Mines/media/mine.mp3"
};

function playSound(sound) {
    const audio = new Audio(sound);
    audio.play();
}


const multipliers = [
    [1.01, 1.08, 1.12, 1.18, 1.24, 1.30, 1.37, 1.46, 1.55, 1.65, 1.77, 1.99, 2.06, 2.25, 2.47, 2.75, 3.09, 3.54, 4.12, 4.95, 6.19, 8.25, 12.38, 24.75],
    [1.08, 1.17, 1.29, 1.41, 1.56, 1.74, 1.94, 2.18, 2.47, 2.83, 3.26, 3.81, 4.50, 5.40, 6.60, 8.25, 10.61, 14.14, 19.80, 29.70, 49.50, 99.00, 297.00],
    [1.12, 1.29, 1.48, 1.71, 2.00, 2.35, 2.79, 3.35, 4.07, 5.00, 6.26, 7.96, 10.35, 13.80, 18.97, 27.11, 40.66, 65.06, 113.9, 227.7, 569.3, 2277],
    [1.18, 1.41, 1.71, 2.09, 2.58, 3.23, 4.09, 5.26, 6.88, 9.17, 12.51, 17.52, 25.3, 37.95, 59.64, 99.39, 178.9, 357.8, 834.9, 2504, 12523],
    [1.24, 1.56, 2.00, 2.58, 3.39, 4.52, 6.14, 8.5, 12.04, 17.52, 26.27, 40.87, 66.41, 113.9, 208.7, 417.5, 939.3, 2504, 8766, 52598],
    [1.30, 1.74, 2.35, 3.23, 4.52, 6.46, 9.44, 14.17, 21.89, 35.03, 58.38, 102.17, 189.75, 379.50, 834.90, 2087, 6261, 25047, 175329],
    [1.37, 1.94, 2.79, 4.09, 6.14, 9.44, 14.95, 24.47, 41.60, 73.95, 138.66, 277.33, 600.87, 1442, 3965, 13219, 59486, 475893],
    [1.46, 2.18, 3.35, 5.26, 8.50, 14.17, 24.47, 44.05, 83.20, 166.40, 356.56, 831.98, 2163, 6489, 23794, 118973, 1070759],
    [1.55, 2.47, 4.07, 6.88, 12.04, 21.89, 41.60, 83.20, 176.80, 404.10, 1010, 2828, 9193, 36773, 202254, 2022545],
    [1.65, 2.83, 5.00, 9.17, 17.52, 35.03, 73.95, 166.40, 404.10, 1077, 3232, 11314, 49031, 294188, 3236072],
    [1.77, 3.26, 6.26, 12.51, 26.77, 58.38, 138.66, 356.56, 1010, 3232, 12123, 56574, 367735, 4412826],
    [1.90, 3.81, 7.96, 17.52, 40.87, 102.17, 277.33, 831.98, 2828, 11314, 56574, 396022, 5148297],
    [2.06, 4.50, 10.35, 25.30, 66.41, 189.75, 600.87, 2163, 9193, 49031, 367735, 5148297],
    [2.25, 5.4, 13.80, 37.95, 113.85, 379.50, 1442, 6489, 36773, 294188, 4412826],
    [2.47, 6.60, 18.97, 59.64, 208.72, 834.90, 3965, 23794, 202254, 3236072],
    [2.75, 8.25, 27.11, 99.39, 417.45, 2087, 13219, 118973, 2022545],
    [3.09, 10.61, 40.66, 178.91, 939.26, 6261, 59486, 1070759],
    [3.54, 14.14, 65.06, 357.81, 2504, 25047, 475893],
    [4.12, 19.80, 113.85, 834.90, 8768, 175329],
    [4.95, 29.70, 227.70, 2504],
    [6.19, 49.50, 569.30],
    [8.25, 99, 2277],
    [12.37, 297],
    [24.75]
];


function showResultModal(title, message){
    resultTitle.textContent = title;
    resultMessage.textContent = message;
    resultModal.style.display = "block";
}

function closeResultModal(){
    resultModal.style.display = "none";
}

function resetRoundUI(){
    
    minePositions = [];
    revealedCells = 0;
    currentProfit = 0;


    gridElement.innerHTML = "";
    for (let i = 0; i < SIZE * SIZE; i++) {
        const cell = document.createElement("div");
        cell.classList.add("cell");
        cell.classList.add("revealed");
        cell.style.backgroundColor = "#ccc";
        cell.dataset.index = i;
        gridElement.appendChild(cell);
    }

    
    minesInput.classList.remove("disabled");
    betSizeInput.classList.remove("disabled");
    startButton.disabled = false;


    cashoutButton.disabled = true;
    cashoutButton.style.display = "none";
    profitInput.value = "0.00";
}










for (let i = 0; i < SIZE * SIZE; i++) {
    const cell = document.createElement("div");
    cell.classList.add("cell");
    cell.classList.add("revealed");
    cell.style.backgroundColor = "#ccc";
    cell.dataset.index = i;
    gridElement.appendChild(cell);
}


function startGame() {
    gameOver = false;
    
    const numMines = parseInt(minesInput.value);
    betSize = parseFloat(betSizeInput.value);

    if (isNaN(numMines) || numMines < 1 || numMines > 24) {
        showToast("Number of mines must be between 1 and 24.", "error");
        return;
    }
    if (isNaN(betSize) || betSize <= 0) {
        showToast("Bet size must be greater than 🥩0.", "error");
        return;
    }

    if (betSize > balance) {
        showToast("Not enough 🥩 balance to start this game.", "error");
        return;
    }

    playSound(sounds.start);

    balance -= betSize;
    document.getElementById('usermeat').textContent = balance.toFixed(2);


    startButton.disabled = true;
    exitButton.style.display = "none";
    profitInput.style.display = 'inline-block'; 
    profitInput.value = "0.00 (0.0x)";
    cashoutButton.disabled = true;
    cashoutButton.style.display = 'inline-block';


    gridElement.innerHTML = "";
    minePositions = [];
    revealedCells = 0;
    currentProfit = 0;


    while (minePositions.length < numMines) {
        const position = Math.floor(Math.random() * SIZE * SIZE);
        if (!minePositions.includes(position)) {
            minePositions.push(position);
        }
    }


    for (let i = 0; i < SIZE * SIZE; i++) {
        const cell = document.createElement("div");
        cell.classList.add("cell");
        cell.dataset.index = i;


        cell.removeEventListener("click", handleCellClick); 


        cell.addEventListener("click", () => revealCell(cell, i));
        gridElement.appendChild(cell);
    }
}

function revealCell(cell, index) {

    if (gameOver) return;  

    if (cell.classList.contains("revealed")) return;  

    cell.classList.add("revealed");
    const content = document.createElement("div");

    if (minePositions.includes(index)) {
        gameOver = true; 
        
        playSound(sounds.mine);
        cell.classList.add("mine");
        content.textContent = "💣";
        content.classList.add("mine");
        cell.appendChild(content);

        totalLoss += betSize;

        revealAllCells();


        setTimeout(() => {
            endGame(false);
        }, 500); 
    } else {
        playSound(sounds.emerald);
        cell.classList.add("emerald");
        content.textContent = "💎";
        content.classList.add("emerald");
        cell.appendChild(content);
        revealedCells++;

        updateProfit();
        if (revealedCells === SIZE * SIZE - minePositions.length) {
            endGame(true);
        }
    }
}



function updateProfit() {
    const numMines = parseInt(minesInput.value);
    const multiplierRow = multipliers[numMines - 1];
    if (revealedCells - 1 < multiplierRow.length) {
        const currentMultiplier = multiplierRow[revealedCells - 1];
        currentProfit = betSize * currentMultiplier;
        cashoutButton.disabled = false;
        profitInput.value = `${currentProfit.toFixed(2)} (${currentMultiplier.toFixed(2)}x)`;
    } else {
        alert("No multiplier available for this many revealed cells!");
    }
}

function endGame(won, reason = "end") {
    gameOver = true;
    
    setTimeout(() => {

        if (won) {
            balance += currentProfit;
            document.getElementById('usermeat').textContent = balance.toFixed(2);
            totalWin += currentProfit;
            showResultModal("You Win!", `You earned 🥩${currentProfit.toFixed(2)}.`);
        } else {
            totalLoss += betSize;
            showResultModal("You Lose", `You lost 🥩${betSize.toFixed(2)}.`);
        }



        startButton.disabled = false;
        exitButton.style.display = "inline-block";
    }, 1500); 
}




function cashOut() {
    playSound(sounds.cashout);
    cashoutButton.disabled = true;


    endGame(true, "cashout");
}


startButton.addEventListener("click", startGame);
cashoutButton.addEventListener("click", cashOut);

betSizeInput.addEventListener("blur", () => {
let value = parseFloat(betSizeInput.value);
if (!isNaN(value)) betSizeInput.value = value.toFixed(2);
else betSizeInput.value = "0.00";
});


playAgainButton.addEventListener("click", () => {
    closeResultModal();
    resetRoundUI();
});

endGameButton.addEventListener("click", () => {

    exitButton.click();
});


function handleCellClick(event) {

    revealCell(event.target, event.target.dataset.index);
}



function revealAllCells() {
    const cells = document.querySelectorAll("#grid .cell");

    cells.forEach((cell, index) => {
        if (cell.classList.contains("revealed")) return;

        cell.classList.add("revealed");
        const content = document.createElement("div");

        if (minePositions.includes(index)) {
            cell.classList.add("mine");
            content.textContent = "💣";
            content.classList.add("mine");
        } else {
            cell.classList.add("emerald");
            content.textContent = "💎";
            content.classList.add("emerald");
        }

        cell.appendChild(content);
    });
}



</script>
}

